{
  "name": "playground",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run --stream '/^dev:/'",
    "dev:client": "vite",
    "dev:db": "json-server --port 7777 db.json",
    "dev_devtools": "pnpm run -C ../devtools build:panel -w",
    "preview": "vite preview",
    "build": "vite build",
    "type-check": "vue-tsc --build --force"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@pinia/colada": "workspace:*",
    "@pinia/colada-plugin-cache-persister": "workspace:^",
    "@pinia/colada-plugin-debug": "workspace:^",
    "@pinia/colada-plugin-retry": "workspace:^",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "@vueuse/router": "^14.3.0",
    "fuse.js": "^7.4.2",
    "mande": "^2.0.10",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "water.css": "^2.1.1"
  },
  "devDependencies": {
    "@nostics/unplugin": "^1.1.0",
    "@pinia/colada-devtools": "workspace:^",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.2",
    "json-server": "0.17.4",
    "npm-run-all2": "^9.0.2",
    "tailwindcss": "^4.3.2",
    "typescript": "~7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vue-tsc": "^3.3.7"
  }
}
